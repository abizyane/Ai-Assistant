  },
  "description": "RAG pipeline operational health: request throughput, LLM latency percentiles (P50/P95/P99), error rate, retrieval component durations, agent loop activity, and vector search performance.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": false,
      "keepTime": true,
      "tags": [],
      "targetBlank": true,
      "title": "RAG Service Logs (Loki)",
      "tooltip": "Explore Loki logs for {service=\"rag\"} correlated with this time range",
      "type": "link",
      "url": "/explore?orgId=1&left=%7B%22datasource%22%3A%22Loki%22%2C%22queries%22%3A%5B%7B%22refId%22%3A%22A%22%2C%22expr%22%3A%22%7Bservice%3D%5C%22rag%5C%22%7D%22%7D%5D%7D"
    }
  ],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "description": "Rate of user queries entering the RAG pipeline per second (5m window), derived from session message counters. Spikes may indicate traffic bursts or load-test runs. SLO: sustained < 50 rps per instance.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false
          },
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "red", "value": 80 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "rate(session_messages_appended_total{role=\"user\"}[5m])",
          "refId": "A",
          "legendFormat": "User Queries/s"
        }
      ],
      "title": "User Query Request Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "description": "LLM request duration percentiles (P50/P95/P99) by provider and model. SLO: P95 < 5 s, P99 < 10 s. Yellow threshold: 1 s; Red: 5 s. Filter by $endpoint to narrow to a specific HTTP path once http_request_duration_seconds is instrumented.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false
          },
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "histogram_quantile(0.5, sum(rate(llm_request_duration_seconds_bucket[5m])) by (le, provider, model))",
          "refId": "A",
          "legendFormat": "P50 {{provider}}/{{model}}"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(llm_request_duration_seconds_bucket[5m])) by (le, provider, model))",
          "refId": "B",
          "legendFormat": "P95 {{provider}}/{{model}}"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(llm_request_duration_seconds_bucket[5m])) by (le, provider, model))",
          "refId": "C",
          "legendFormat": "P99 {{provider}}/{{model}}"
        }
      ],
      "title": "LLM Request Latency P50 / P95 / P99",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "description": "Successful answer generation rate (completions that produced output tokens). A drop relative to query rate signals elevated LLM errors. Dedicated error counter `llm_errors_total` is planned for a future task.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false
          },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "id": 3,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "rate(generation_tokens_total{kind=\"input\"}[5m])",
          "refId": "A",
          "legendFormat": "Successful Completions/s"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "rate(llm_request_duration_seconds_count[5m]) - rate(generation_tokens_total{kind=\"input\"}[5m])",
          "refId": "B",
          "legendFormat": "Error Rate Proxy (LLM calls without token output)"
        }
      ],
      "title": "Error Rate (Completion Success Proxy)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "description": "P95 duration of each retrieval pipeline component: embedding (BGE-M3), vector search (dense/hybrid pgvector), and reranking (BGE-Reranker). Sum approximates end-to-end retrieval latency. Yellow: 2 s; Red: 10 s.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false
          },
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "id": 4,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(embedding_request_duration_seconds_bucket[5m])) by (le, model))",
          "refId": "A",
          "legendFormat": "Embedding P95 {{model}}"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(vector_search_duration_seconds_bucket[5m])) by (le, search_type))",
          "refId": "B",
          "legendFormat": "Vector Search P95 ({{search_type}})"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(reranker_request_duration_seconds_bucket[5m])) by (le))",
          "refId": "C",
          "legendFormat": "Reranker P95"
        }
      ],
      "title": "Retrieval Pipeline Component Duration P95",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "description": "Approximate agent loop activity: number of assistant responses appended per 5-minute window. Each response corresponds to one agent graph execution (retrieve → grade → rewrite → generate). A high count indicates frequent query rewrites.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false
          },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "id": 5,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "increase(session_messages_appended_total{role=\"assistant\"}[5m])",
          "refId": "A",
          "legendFormat": "Agent Completions (5m window)"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "increase(session_messages_appended_total{role=\"user\"}[5m])",
          "refId": "B",
          "legendFormat": "User Queries (5m window)"
        }
      ],
      "title": "Agent Loop Counts (Message Activity)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "description": "Vector search latency P50/P95 broken down by search type (dense cosine vs hybrid dense+BM25 RRF). SLO: P95 < 500 ms for dense, < 2 s for hybrid. Yellow: 0.5 s; Red: 2 s.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false
