        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "histogram_quantile(0.5, sum(rate(vector_search_duration_seconds_bucket[5m])) by (le, search_type))",
          "refId": "A",
          "legendFormat": "P50 {{search_type}}"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(vector_search_duration_seconds_bucket[5m])) by (le, search_type))",
          "refId": "B",
          "legendFormat": "P95 {{search_type}}"
        }
      ],
      "title": "Vector Search Latency by Type",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "description": "BGE-M3 embedding request duration P50/P95 by model. Embedding is the first step in the retrieval pipeline; high latency here cascades to overall query latency. SLO: P95 < 3 s. Yellow: 1 s; Red: 3 s.",
      "fieldConfig": {
        "defaults": {
