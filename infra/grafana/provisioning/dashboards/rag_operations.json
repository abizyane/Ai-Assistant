  "description": "RAG pipeline operational metrics: LLM latency, vector search performance, embedding throughput, reranker pipeline, and session activity.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "icon": "external link",
      "targetBlank": true,
      "title": "Correlated Logs (Loki: service=rag)",
      "tooltip": "Open Loki Explore filtered to {service=\"rag\"} for correlated log analysis",
      "type": "link",
      "url": "/explore?orgId=1&left=%7B%22datasource%22%3A%22Loki%22%2C%22queries%22%3A%5B%7B%22refId%22%3A%22A%22%2C%22expr%22%3A%22%7Bservice%3D%5C%22rag%5C%22%7D%22%7D%5D%2C%22range%22%3A%7B%22from%22%3A%22now-1h%22%2C%22to%22%3A%22now%22%7D%7D"
    }
