{
  "__inputs": [],
  "__requires": [],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "LLM cost and usage tracking: token consumption rates, request counts, retry rates, and estimated API cost based on Gemini Flash pricing.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "icon": "external link",
      "targetBlank": true,
      "title": "Correlated Logs (Loki: service=rag)",
      "tooltip": "Open Loki Explore filtered to {service=\"rag\"} for LLM error investigation",
      "type": "link",
      "url": "/explore?orgId=1&left=%7B%22datasource%22%3A%22Loki%22%2C%22queries%22%3A%5B%7B%22refId%22%3A%22A%22%2C%22expr%22%3A%22%7Bservice%3D%5C%22rag%5C%22%7D%22%7D%5D%2C%22range%22%3A%7B%22from%22%3A%22now-1h%22%2C%22to%22%3A%22now%22%7D%7D"
    }
  ],
  "panels": [
    {
      "datasource": "Prometheus",
      "description": "Rate of LLM generation calls per second, grouped by invocation kind (input = request dispatched, output = response received). Tracked via generation_tokens_total counter incremented once per generate() call in GenerateAnswerUseCase. Input and output counts should be equal under normal operation; a divergence indicates incomplete generations or errors.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "calls/s",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 15,
            "gradientMode": "opacity",
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "insertNulls": false,
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "none"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 10},
              {"color": "red", "value": 50}
            ]
          },
          "unit": "reqps"
        }
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "options": {
        "legend": {
          "calcs": ["mean", "lastNotNull", "sum"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(generation_tokens_total[5m])) by (kind)",
          "legendFormat": "kind={{kind}}",
          "refId": "A"
        }
      ],
      "title": "Token Call Rate by Kind (Input / Output)",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "description": "Cumulative count of LLM invocations for input (request dispatched). Under normal operation this equals the number of successful GenerateAnswerUseCase.execute() calls. Counter resets on application restart.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1000},
              {"color": "red", "value": 10000}
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": {"h": 6, "w": 8, "x": 0, "y": 8},
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(generation_tokens_total{kind=\"input\"})",
          "legendFormat": "Input Calls",
          "refId": "A"
        }
      ],
      "title": "Total LLM Input Calls",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "description": "Cumulative count of LLM invocations where a response was successfully received (output). Comparing with Total LLM Input Calls reveals the completion rate. A persistent gap indicates retries or errors causing dropped completions.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1000},
              {"color": "red", "value": 10000}
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": {"h": 6, "w": 8, "x": 8, "y": 8},
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(generation_tokens_total{kind=\"output\"})",
          "legendFormat": "Output Calls",
          "refId": "A"
        }
      ],
      "title": "Total LLM Output Calls",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "description": "Estimated hourly cost in USD based on Gemini 2.0 Flash pricing applied to call rates. Formula: input_call_rate * $0.000005 + output_call_rate * $0.000015 per hour. IMPORTANT: generation_tokens_total tracks call counts (not actual tokens); this is a throughput-based cost proxy. For accurate token-based cost, instrument actual token counts from GenerationResult.input_tokens/output_tokens. Threshold: yellow ≥ $0.10/hr, red ≥ $1.00/hr.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "decimals": 6,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.1},
              {"color": "red", "value": 1.0}
            ]
          },
          "unit": "currencyUSD"
        }
      },
      "gridPos": {"h": 6, "w": 8, "x": 16, "y": 8},
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(generation_tokens_total{kind=\"input\"}[1h])) * 0.000005 + sum(rate(generation_tokens_total{kind=\"output\"}[1h])) * 0.000015",
          "legendFormat": "Estimated Cost/hr",
          "refId": "A"
        }
      ],
      "title": "Estimated LLM Cost (per Hour)",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "description": "Rate of LLM requests per second grouped by provider and model, measured by the llm_request_duration_seconds histogram count. Use this panel to compare throughput across providers (gemini, openai) and models. Higher rate indicates successful completions, not retries. Retries are transparent in the histogram but inflate wall-clock latency.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "req/s",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "insertNulls": false,
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "none"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 10},
              {"color": "red", "value": 50}
            ]
          },
          "unit": "reqps"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 14},
      "id": 5,
      "options": {
        "legend": {
          "calcs": ["mean", "lastNotNull"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(llm_request_duration_seconds_count[5m])) by (provider, model)",
          "legendFormat": "{{provider}} / {{model}}",
          "refId": "A"
        }
      ],
      "title": "LLM Request Rate by Provider / Model",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "description": "Median number of citations extracted per LLM generation, tracked by the generation_citations_count histogram. Each citation corresponds to a chunk reference parsed from the LLM output. Low citation counts (< 1 median) may indicate the LLM is not grounding its answers. High counts (> 5 median) may indicate over-quoting. SLO: median 1–4 citations per generation.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "citations",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "insertNulls": false,
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "none"
            },
            "thresholdsStyle": {
              "mode": "line+area"
            }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 5},
              {"color": "red", "value": 10}
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 14},
      "id": 6,
      "options": {
        "legend": {
          "calcs": ["mean", "lastNotNull"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.50, sum(rate(generation_citations_count_bucket[5m])) by (le))",
          "legendFormat": "P50 citations/generation",
          "refId": "A"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, sum(rate(generation_citations_count_bucket[5m])) by (le))",
          "legendFormat": "P95 citations/generation",
          "refId": "B"
        }
      ],
      "title": "Citations Per Generation (P50 / P95)",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["rag"],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "title": "LLM Costs",
  "uid": "llm-costs",
  "version": 1
}
