# --- App ---
GEMINI_API_KEY=your_gemini_api_key_here
RAG_LLM__PROVIDER=gemini
RAG_LLM__MODEL=gemini-2.0-flash-exp
RAG_LLM__API_KEY=your_gemini_api_key_here

# --- Main DB (pgvector) ---
POSTGRES_USER=raguser
POSTGRES_PASSWORD=ragpassword
POSTGRES_DB=ragdb
DATABASE_URL=postgresql+asyncpg://raguser:ragpassword@db:5432/ragdb

# --- Langfuse DB ---
LANGFUSE_DB_USER=langfuse
LANGFUSE_DB_PASSWORD=langfusepassword
LANGFUSE_DB_NAME=langfuse

# --- Langfuse App ---
LANGFUSE_SECRET=changeme-in-production
LANGFUSE_SALT=changeme-in-production
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
LANGFUSE_SECRET_KEY=your_langfuse_secret_key

# --- Grafana ---
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# --- RAG Settings (pydantic-settings prefix RAG_) ---
RAG_LLM__TEMPERATURE=0.1
RAG_LLM__MAX_TOKENS=4096

RAG_EMBEDDING__MODEL=BAAI/bge-m3
RAG_EMBEDDING__BATCH_SIZE=32
RAG_EMBEDDING__CACHE_DIR=/tmp/hf_cache

RAG_VECTORSTORE__DATABASE_URL=postgresql+asyncpg://raguser:ragpassword@db:5432/ragdb
RAG_VECTORSTORE__TABLE_NAME=chunks
RAG_VECTORSTORE__HNSW_M=16
RAG_VECTORSTORE__HNSW_EF_CONSTRUCTION=64
RAG_VECTORSTORE__TOP_K_DENSE=20
RAG_VECTORSTORE__TOP_K_SPARSE=20
RAG_VECTORSTORE__TOP_K_RERANK=5

RAG_RERANKER__MODEL=BAAI/bge-reranker-v2-m3
RAG_RERANKER__BATCH_SIZE=16

RAG_LANGFUSE__HOST=http://langfuse:3000
RAG_LANGFUSE__PUBLIC_KEY=your_langfuse_public_key
RAG_LANGFUSE__SECRET_KEY=your_langfuse_secret_key
RAG_LANGFUSE__ENABLED=false

RAG_PROMETHEUS__PORT=9090
RAG_PROMETHEUS__PATH=/metrics

RAG_AGENT__MAX_REWRITE_ATTEMPTS=1
RAG_AGENT__MAX_REGEN_ATTEMPTS=1
RAG_AGENT__MAX_STEPS=15
